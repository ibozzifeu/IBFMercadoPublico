    "ollama:extract": "npx tsx --tsconfig tsconfig.scripts.json scripts/extract-dataset.ts",
    "ollama:train": "npx tsx --tsconfig tsconfig.scripts.json scripts/train-classifier.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@google/generative-ai": "^0.3.0",
    "@prisma/client": "^5.7.0",
    "axios": "^1.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.292.0",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.10.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
