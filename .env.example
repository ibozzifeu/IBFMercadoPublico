# ========== BASE DE DATOS (PostgreSQL Local) ==========
# Configuración para PostgreSQL local
# Formato: postgresql://[usuario]:[password]@[host]:[puerto]/[database]
DATABASE_URL="postgresql://usuario:password@localhost:5432/mercado_publico"

# ========== MERCADO PÚBLICO API ==========
# Ticket de autenticación para API Mercado Público
# Obtener en: https://www.mercadopublico.cl → Servicios → API
NEXT_PUBLIC_MP_TICKET=tu_ticket_aqui
# URL base de API Mercado Público (no cambiar)
NEXT_PUBLIC_MP_BASE_URL=https://api.mercadopublico.cl/servicios/v1/publico

# ========== GEMINI API ==========
# Clave de API de Google Gemini
# Obtener en: https://ai.google.dev/
GEMINI_API_KEY=tu_clave_aqui
# Modelo de Gemini a usar (gemini-2.0-flash, gemini-pro, etc.)
GEMINI_MODEL=gemini-2.0-flash

# ========== APLICACIÓN ==========
# Ambiente (development, production, test)
NEXT_PUBLIC_APP_ENV=development
# URL de la aplicación local
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Node environment
NODE_ENV=development

# ========== SINCRONIZACIÓN ==========
# Intervalo de sincronización en minutos (0 = deshabilitado, 60 = cada hora)
SYNC_INTERVAL_MINUTES=60
# Cantidad máxima de licitaciones a procesar por ejecución
SYNC_MAX_LIMIT=100
# Secret para proteger endpoint de sincronización (generar: openssl rand -hex 32)
CRON_SECRET=tu_secret_aqui
